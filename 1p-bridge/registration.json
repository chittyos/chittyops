{
  "name": "chitty-1p-bridge",
  "description": "VM-resident Node service: bridges 1Password to Cloudflare Secrets Store, exposes chitty-op CLI for operator-grade 1P access on chittyserv-dev.",
  "tier": 3,
  "category": "operational",
  "deployment": "systemd-on-vm",
  "vm": "chittyserv-dev",
  "domain": null,
  "health_endpoint": null,
  "health_method": "systemctl status chitty-1p-bridge-sync.timer",
  "canonical_uri": "chittycanon://core/services/chitty-1p-bridge",
  "charter_uri": "chittycanon://docs/ops/policy/chitty-1p-bridge-charter",
  "architecture_uri": "chittycanon://docs/ops/architecture/chitty-1p-bridge",
  "repo": "https://github.com/chittyos/chittyops",
  "version": "0.1.0",
  "phase": 1,
  "capabilities": [
    "op.get",
    "op.list",
    "op.otp"
  ],
  "dependencies": {
    "upstream": [
      "1password-connect",
      "cloudflare-secrets-store",
      "chittyregistry"
    ],
    "peer": [
      "chittychronicle"
    ]
  },
  "owner": "operator@chitty.cc",
  "repo_path": "1p-bridge",
  "npm_package": "@chittyops/1p-bridge"
}
