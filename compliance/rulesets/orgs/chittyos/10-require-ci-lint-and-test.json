{
  "name": "Require CI / lint-and-test",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "~DEFAULT_BRANCH"
      ],
      "exclude": []
    },
    "repository_name": {
      "include": [
        "chittyops"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "CI / lint-and-test"
          }
        ]
      }
    }
  ],
  "bypass_actors": []
}
